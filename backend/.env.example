# Database - get this from neon.tech (free)
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# JWT Secret - any long random string
JWT_SECRET=your_super_secret_key_change_this_in_production

# Server Port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email - use Gmail App Password (not your real password)
# Go to Google Account > Security > 2FA > App Passwords
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=SmileCare Dental <yourname@gmail.com>

# Admin credentials (for first login)
ADMIN_EMAIL=admin@smilecare.in
ADMIN_PASSWORD=Admin@123
